POKE_DB.forEach(p=>{p.level=50;p.allMoves=p.allMoves.map(m=>({...m,maxPp:m.pp}));});

// ══════════════════════════════════════════
// 팀 선택 상태
// ══════════════════════════════════════════
let selectedTeam = [null, null, null]; // {pokeData, moves[], nature, item, evs{}}
let modalSlotIdx = -1;
let modalPokeIdx = -1;
let tempMoves = [];
let genFilter = 0;

function calcStat(base, ev, level, natureMult) {
  return Math.floor((Math.floor((2*base+31+Math.floor(ev/4))*level/100)+5)*natureMult);
}
function calcHp(base, ev, level) {
  return Math.floor((2*base+31+Math.floor(ev/4))*level/100)+level+10;
}

function makeBattlePoke(slot) {
  const p = slot.pokeData;
  const n = slot.nature;
  const ev = slot.evs;
  const lv = 50;
  const maxHp = calcHp(p.hp, ev.hp||0, lv);
  return {
    ...p,
    level: lv,
    maxHp,
    currentHp: maxHp,
    atkStat:  calcStat(p.atk,  ev.atk||0, lv, nm(n,'atk')),
    defStat:  calcStat(p.def,  ev.def||0, lv, nm(n,'def')),
    spaStat:  calcStat(p.spa,  ev.spa||0, lv, nm(n,'spa')),
    spdStat:  calcStat(p.spd,  ev.spd||0, lv, nm(n,'spd')),
    speStat:  calcStat(p.spe,  ev.spe||0, lv, nm(n,'spe')),
    nature: n,
    item: slot.item,
    status: 'none',
    fainted: false,
    confused: false,
    confusionTurns: 0,
    // 하품 상태 (2턴 후 잠듦)
    yawnCounter: 0,
    // 역린 잠금
    outrageTurns: 0,
    outrageMove: null,
    rankAtk:0, rankDef:0, rankSpa:0, rankSpd:0, rankSpe:0,
    moves: slot.moves.map(m=>({...m,pp:m.maxPp})),
    revealed: false, // AI 포켓몬 등장 여부
  };
}

function makeAiPoke(pokeData) {
  const lv = 50;
  const maxHp = calcHp(pokeData.hp, 0, lv);
  const moves = pokeData.allMoves.slice(0,4).map(m=>({...m,pp:m.maxPp}));
  return {
    ...pokeData, level:lv, maxHp, currentHp:maxHp,
    atkStat:calcStat(pokeData.atk,0,lv,1), defStat:calcStat(pokeData.def,0,lv,1),
    spaStat:calcStat(pokeData.spa,0,lv,1), spdStat:calcStat(pokeData.spd,0,lv,1),
    speStat:calcStat(pokeData.spe,0,lv,1),
    nature:'hardy', item:'', status:'none', fainted:false,
    confused:false, confusionTurns:0, yawnCounter:0, outrageTurns:0, outrageMove:null,
    rankAtk:0, rankDef:0, rankSpa:0, rankSpd:0, rankSpe:0,
    moves, revealed: false,
  };
}

// ── 그리드 렌더 ──
function renderGrid(search='', gen=0) {
  const grid = document.getElementById('pokeGrid');
  const selNames = selectedTeam.filter(Boolean).map(s=>s.pokeData.name);
  grid.innerHTML = '';
  POKE_DB.forEach((p,i)=>{
    if (gen>0 && getGen(p.id)!==gen) return;
    if (search && !p.name.includes(search)) return;
    const selOrder = selNames.indexOf(p.name);
    const isSel = selOrder>=0;
    const div = document.createElement('div');
    div.className = 'poke-card' + (isSel?' selected':'');
    div.innerHTML = `
      <div class="sel-num">${isSel?selOrder+1:''}</div>
      <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${p.id}.png" onerror="this.src=''" alt="${p.name}">
      <div class="poke-card-name">#${p.id} ${p.name}</div>
      <div class="poke-card-types">${p.types.map(t=>`<span class="type-badge type-${t}">${t.toUpperCase()}</span>`).join('')}</div>`;
    div.onclick = ()=>onPokeCardClick(i);
    grid.appendChild(div);
  });
}
function filterGrid(v){renderGrid(v,genFilter);}
function setGen(g,btn){genFilter=g;document.querySelectorAll('.gen-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderGrid(document.getElementById('searchInput').value,g);}

function onPokeCardClick(pokeIdx) {
  const p = POKE_DB[pokeIdx];
  const alreadySlot = selectedTeam.findIndex(s=>s&&s.pokeData.name===p.name);
  if (alreadySlot>=0) { openModal(alreadySlot, pokeIdx); return; }
  const emptySlot = selectedTeam.findIndex(s=>!s);
  if (emptySlot<0) { alert('이미 3마리가 선택됐습니다! 슬롯을 클릭해 변경하세요.'); return; }
  openModal(emptySlot, pokeIdx);
}

function clickSlot(idx) {
  if (!selectedTeam[idx]) return;
  const pokeIdx = POKE_DB.findIndex(p=>p.name===selectedTeam[idx].pokeData.name);
  openModal(idx, pokeIdx);
}

function removeSlot(e, idx) {
  e.stopPropagation();
  selectedTeam[idx] = null;
  updateSlotUI();
  renderGrid(document.getElementById('searchInput').value, genFilter);
}

// ── 슬롯 UI 업데이트 ──
function updateSlotUI() {
  selectedTeam.forEach((s,i)=>{
    const el = document.getElementById(`slot${i}`);
    if (s) {
      el.className = 'ts-slot filled';
      el.innerHTML = `<button class="remove-btn" onclick="removeSlot(event,${i})">✕</button>
        <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${s.pokeData.id}.png" onerror="this.src=''">
        <div class="slot-name">${s.pokeData.name}</div>`;
    } else {
      el.className = 'ts-slot';
      el.innerHTML = `<span class="slot-num">${i+1}</span><button class="remove-btn" onclick="removeSlot(event,${i})">✕</button>`;
    }
    el.onclick = ()=>clickSlot(i);
  });
  const full = selectedTeam.every(Boolean);
  document.getElementById('startBattleBtn').disabled = !full;
}

// ══════════════════════════════════════════
// 기술 선택 모달
// ══════════════════════════════════════════
// ══════════════════════════════════════════
// 커스텀 드롭다운 (position:fixed — modal overflow 영향 없음)
// ══════════════════════════════════════════
(function() {
  let openList = null;

  function closeAll() {
    if (openList) { openList.style.display = 'none'; openList = null; }
  }
  document.addEventListener('click', closeAll);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeAll(); });

  window.buildCdd = function(btnId, listId, selectId, getDisabled) {
    const btn    = document.getElementById(btnId);
    const list   = document.getElementById(listId);
    const select = document.getElementById(selectId);
    if (!btn || !list || !select) return;

    btn.onclick = function(e) {
      e.stopPropagation();
      if (openList === list) { closeAll(); return; }
      closeAll();

      const disabled = getDisabled ? getDisabled() : [];
      list.innerHTML = '';
      Array.from(select.options).forEach(function(opt) {
        const isDisabled = opt.value !== '' && disabled.includes(opt.value);
        const item = document.createElement('div');
        item.className = 'cdd-item' +
          (opt.value === select.value ? ' selected' : '') +
          (isDisabled ? ' disabled' : '');
        item.textContent = isDisabled ? opt.text + '  ✗' : opt.text;
        item.onclick = function(ev) {
          ev.stopPropagation();
          if (isDisabled) return;
          select.value = opt.value;
          btn.textContent = opt.text;
          closeAll();
          list.querySelectorAll('.cdd-item').forEach(function(i){ i.classList.remove('selected'); });
          item.classList.add('selected');
        };
        list.appendChild(item);
      });

      const rect = btn.getBoundingClientRect();
      list.style.display  = 'block';
      list.style.position = 'fixed';
      list.style.left     = rect.left + 'px';
      list.style.top      = (rect.bottom + 4) + 'px';
      list.style.minWidth = Math.max(rect.width, 160) + 'px';
      list.style.zIndex   = '999999';

      requestAnimationFrame(function() {
        const listH = list.offsetHeight;
        if (rect.bottom + listH + 4 > window.innerHeight) {
          list.style.top = (rect.top - listH - 4) + 'px';
        }
      });
      openList = list;
    };

    return {
      setValue: function(val) {
        const opt = Array.from(select.options).find(function(o){ return o.value === val; });
        if (opt) { select.value = val; btn.textContent = opt.text; }
      },
      getValue: function() { return select.value; }
    };
  };
})();

function getUsedItems() {
  return selectedTeam
    .map(function(s, i){ return (i !== modalSlotIdx && s && s.item) ? s.item : null; })
    .filter(Boolean);
}

let natureCdd = null, itemCdd = null;

function initDropdowns() {
  natureCdd = window.buildCdd('natureCddBtn', 'natureCddList', 'natureSelect', null);
  itemCdd   = window.buildCdd('itemCddBtn',   'itemCddList',   'itemSelect',   getUsedItems);
}

function openModal(slotIdx, pokeIdx) {
  modalSlotIdx = slotIdx;
  modalPokeIdx = pokeIdx;
  const p = POKE_DB[pokeIdx];
  const existing = selectedTeam[slotIdx];

  document.getElementById('modalTitle').textContent = `${p.name} — 기술 선택`;
  document.getElementById('modalSub').textContent = `${p.types.join(' / ')} | 특성: ${p.ability} | 1~4개 선택`;
  document.getElementById('natureSelect').value = existing?.nature || 'hardy';
  document.getElementById('itemSelect').value = existing?.item || '';
  ['Hp','Atk','Def','Spa','Spd','Spe'].forEach(s=>{
    document.getElementById('ev'+s).value = existing?.evs?.[s.toLowerCase()] || 0;
  });
  updateEvTotal();
  tempMoves = existing?.moves?.map(m=>m.name) || [];
  renderMovePool(p);
  document.getElementById('moveModal').style.display = 'flex';
}
function closeModal(){document.getElementById('moveModal').style.display='none';}

function renderMovePool(p) {
  const pool = document.getElementById('movePool');
  pool.innerHTML = '';
  p.allMoves.forEach(m=>{
    const sel = tempMoves.includes(m.name);
    const btn = document.createElement('button');
    btn.className = 'mpick' + (sel?' selected':'');
    btn.disabled = !sel && tempMoves.length>=4;
    btn.style.color = tc(m.type);
    btn.innerHTML = `<div class="mpick-name">${m.cat==='physical'?'⚔️':m.cat==='special'?'✨':'🔮'} ${m.name}</div>
      <div class="mpick-meta"><span class="move-type-mini type-${m.type}">${m.type.toUpperCase()}</span><span style="font-size:7px;color:var(--text-dim)">${m.power>0?'위력:'+m.power:'변화'} PP:${m.maxPp}</span></div>`;
    btn.onclick=()=>toggleMove(m.name,p);
    pool.appendChild(btn);
  });
  document.getElementById('moveSelCount').textContent = tempMoves.length;
  document.getElementById('modalOkBtn').disabled = tempMoves.length===0;
}

function toggleMove(name, p) {
  const i = tempMoves.indexOf(name);
  if (i>=0) tempMoves.splice(i,1); else { if(tempMoves.length>=4)return; tempMoves.push(name); }
  renderMovePool(p);
}

const EV_KEYS = ['Hp','Atk','Def','Spa','Spd','Spe'];

function updateEvTotal() {
  const total = EV_KEYS.reduce((s,k)=>s+(parseInt(document.getElementById('ev'+k).value)||0),0);
  const el = document.getElementById('evTotalNum');
  el.textContent = total;
  el.style.color = total > 508 ? '#ef4444' : total === 508 ? '#22c55e' : 'var(--text-dim)';
  // 확인 버튼: 기술도 있고 EV도 유효해야 활성화
  document.getElementById('modalOkBtn').disabled = tempMoves.length === 0 || total > 508;
  // 경고 문구
  const warn = document.getElementById('evWarnMsg');
  if (warn) warn.style.display = total > 508 ? 'block' : 'none';
}

function clampEv(changedKey) {
  // 방금 바뀐 스탯이 252 초과면 252로
  const el = document.getElementById('ev' + changedKey);
  let val = parseInt(el.value) || 0;
  if (val < 0) val = 0;
  if (val > 252) val = 252;
  el.value = val;

  // 현재 총합 계산
  let total = EV_KEYS.reduce((s,k)=>s+(parseInt(document.getElementById('ev'+k).value)||0),0);

  // 508 초과분을 방금 수정한 스탯에서 깎기
  if (total > 508) {
    const over = total - 508;
    val = Math.max(0, val - over);
    el.value = val;
  }

  updateEvTotal();
}

function confirmModal() {
  if (tempMoves.length === 0) return;

  // EV 합계 최종 검증
  const total = EV_KEYS.reduce((s,k)=>s+(parseInt(document.getElementById('ev'+k).value)||0),0);
  if (total > 508) {
    // 혹시 모를 엣지케이스 — 버튼이 이미 비활성이지만 이중 방어
    const warn = document.getElementById('evWarnMsg');
    if (warn) { warn.style.display = 'block'; warn.style.animation = 'none'; void warn.offsetWidth; warn.style.animation = ''; }
    return;
  }

  const p = POKE_DB[modalPokeIdx];
  const moves = p.allMoves.filter(m=>tempMoves.includes(m.name)).map(m=>({...m,pp:m.maxPp}));
  const evs = {};
  ['hp','atk','def','spa','spd','spe'].forEach(s=>{
    evs[s] = Math.min(252, parseInt(document.getElementById('ev'+s[0].toUpperCase()+s.slice(1)).value)||0);
  });
  selectedTeam[modalSlotIdx] = {
    pokeData: p,
    moves,
    nature: document.getElementById('natureSelect').value,
    item: document.getElementById('itemSelect').value,
    evs,
  };
  closeModal();
  updateSlotUI();
  renderGrid(document.getElementById('searchInput').value, genFilter);
}

// ══════════════════════════════════════════
// 게임 상태
// ══════════════════════════════════════════
let G = {}; // 전역 게임 상태

function startBattle() {
  if (!selectedTeam.every(Boolean)) return;
  checkServer();

  // AI 팀 랜덤 구성
  const pool = [...POKE_DB];
  const aiTeam = [];
  while (aiTeam.length < 3) {
    const i = Math.floor(Math.random()*pool.length);
    aiTeam.push(makeAiPoke(pool.splice(i,1)[0]));
  }

  G = {
    playerTeam: selectedTeam.map(s=>makeBattlePoke(s)),
    aiTeam,
    playerIdx: 0,
    aiIdx: 0,
    turn: 1,
    weather: 'none',
    weatherTurns: 0,
    waiting: false,
    over: false,
  };

  document.getElementById('teamSelectScreen').style.display = 'none';
  document.getElementById('battleScreen').style.display = 'block';
  clearLog();
  addLog('🎮 배틀 시작!','log-sys');
  addLog(`💪 ${G.playerTeam[0].name} vs ${G.aiTeam[0].name}!`,'log-new');
  G.aiTeam[0].revealed = true;
  renderBattle();
  switchTab('fight');
}

function goTeamSelect() {
  document.getElementById('resultOverlay').classList.remove('show');
  document.getElementById('battleScreen').style.display = 'none';
  document.getElementById('teamSelectScreen').style.display = 'block';
}
function rematch() {
  document.getElementById('resultOverlay').classList.remove('show');
  startBattle();
}

// ══════════════════════════════════════════
// 렌더링
// ══════════════════════════════════════════
function renderBattle() {
  const pp = G.playerTeam[G.playerIdx];
  const ai = G.aiTeam[G.aiIdx];

  // 플레이어
  document.getElementById('playerSprite').src = spriteUrl(pp.id, false);
  document.getElementById('playerName').textContent = pp.name;
  setHp('playerHpBar','playerHpNum', pp.currentHp, pp.maxHp);
  setTypes('playerTypes', pp.types);
  setStatusBadge('playerStatus', pp);
  document.getElementById('playerAbility').textContent = `특성: ${pp.ability}`;
  document.getElementById('playerItem').textContent = pp.item ? `📦${itemName(pp.item)}` : '';

  // AI
  if (ai.revealed) {
    document.getElementById('oppSprite').src = spriteUrl(ai.id, true);
    document.getElementById('oppName').textContent = ai.name;
    setTypes('oppTypes', ai.types);
    document.getElementById('oppAbility').textContent = `특성: ${ai.ability}`;
    setStatusBadge('oppStatus', ai);
  } else {
    document.getElementById('oppSprite').src = '';
    document.getElementById('oppName').textContent = '???';
    document.getElementById('oppTypes').innerHTML = '';
    document.getElementById('oppAbility').textContent = '';
  }
  setHp('oppHpBar','oppHpNum', ai.currentHp, ai.maxHp);

  // 파티
  renderParty('playerParty', G.playerTeam, G.playerIdx, false);
  renderParty('oppParty', G.aiTeam, G.aiIdx, true);

  // 날씨
  const wl = {none:'— 맑음 —',rain:'🌧️ 비',sun:'☀️ 쾌청',sandstorm:'🌪️ 모래바람',hail:'🌨️ 싸라기눈'};
  const wb = document.getElementById('weatherBanner');
  wb.textContent = (wl[G.weather]||'') + (G.weatherTurns>0?` (${G.weatherTurns}턴)`:'');
  wb.className = 'weather-banner' + (G.weather!=='none'?' '+G.weather:'');

  document.getElementById('turnCounter').textContent = `TURN ${G.turn} / 100`;

  // 기술 버튼
  renderMoveButtons();
  renderSwitchButtons();
}

function renderParty(elId, team, activeIdx, isAi) {
  const el = document.getElementById(elId);
  el.innerHTML = team.map((p,i)=>{
    if (isAi && !p.revealed) {
      return `<div class="party-slot hidden-slot ${p.fainted?'fainted':''} ${i===activeIdx?'active':''}">?</div>`;
    }
    return `<div class="party-slot ${p.fainted?'fainted':''} ${i===activeIdx?'active':''}">
      <img src="${spriteUrl(p.id)}" onerror="this.style.display='none'" title="${p.name}"></div>`;
  }).join('');
}

function renderMoveButtons() {
  const pp = G.playerTeam[G.playerIdx];
  const ai = G.aiTeam[G.aiIdx];
  const grid = document.getElementById('movesGrid');
  grid.innerHTML = '';

  // 역린 잠금 상태면 역린만 표시
  const locked = pp.outrageTurns > 0;

  pp.moves.forEach((m,i)=>{
    const mult = typeMult(m.type, ai.types);
    let effHtml = '';
    if (m.cat!=='status') {
      if (mult===0) effHtml='<span class="move-eff eff-imm">✗ 무효</span>';
      else if (mult>=2) effHtml='<span class="move-eff eff-sup">◎ 효과적!</span>';
      else if (mult<=0.5) effHtml='<span class="move-eff eff-res">△ 비효과</span>';
    }
    const catIcon = m.cat==='physical'?'⚔️':m.cat==='special'?'✨':'🔮';
    const isLockedMove = locked && m.special==='outrage';
    const btn = document.createElement('button');
    btn.className = 'move-btn';
    btn.style.color = tc(m.type);
    btn.disabled = m.pp<=0 || G.waiting || G.over || (locked && !isLockedMove);
    btn.innerHTML = `<span class="move-name">${catIcon} ${m.name}${locked&&isLockedMove?' <span class="locked-badge">LOCKED</span>':''}</span>
      <div class="move-meta"><span class="move-type-mini type-${m.type}">${m.type.toUpperCase()}</span><span class="move-power">${m.power>0?'위력:'+m.power:'변화'}</span><span class="move-pp">PP ${m.pp}/${m.maxPp}</span>${effHtml}</div>`;
    btn.onclick=()=>playerMove(i);
    grid.appendChild(btn);
  });
}

function renderSwitchButtons() {
  const grid = document.getElementById('switchGrid');
  grid.innerHTML = '';
  G.playerTeam.forEach((p,i)=>{
    if (i===G.playerIdx) return;
    const ratio = p.currentHp/p.maxHp;
    const bc = ratio>.5?'#22c55e':ratio>.25?'#eab308':'#ef4444';
    const btn = document.createElement('button');
    btn.className='switch-btn';
    btn.disabled = p.fainted||G.waiting||G.over;
    btn.innerHTML=`<img class="sw-sprite" src="${spriteUrl(p.id)}" onerror="this.style.display='none'">
      <div style="flex:1"><div class="sw-name">${p.name}${p.fainted?' (쓰러짐)':''}</div>
      <div class="sw-hp-bar"><div class="sw-hp-fill" style="width:${ratio*100}%;background:${bc}"></div></div></div>
      <span style="font-size:8px;color:var(--text-dim)">HP ${Math.max(0,p.currentHp)}/${p.maxHp}</span>`;
    btn.onclick=()=>playerSwitch(i);
    grid.appendChild(btn);
  });
}

// ══════════════════════════════════════════
// 배틀 엔진
// ══════════════════════════════════════════
async function playerMove(moveIdx) {
  if (G.waiting||G.over) return;
  G.waiting = true;
  setButtonsDisabled(true);

  const pp = G.playerTeam[G.playerIdx];
  const ai = G.aiTeam[G.aiIdx];
  const pMove = pp.outrageTurns>0 ? pp.moves.find(m=>m.special==='outrage') : pp.moves[moveIdx];
  const aiMove = chooseAiMove(ai, pp);

  // 선공 판정
  const pSpe = calcEffSpe(pp);
  const aiSpe = calcEffSpe(ai);
  if (pSpe >= aiSpe) {
    await execMove(pp, pMove, ai, true);
    if (!ai.fainted && !G.over) { await sleep(500); await execMove(ai, aiMove, pp, false); }
  } else {
    await execMove(ai, aiMove, pp, false);
    if (!pp.fainted && !G.over) { await sleep(500); await execMove(pp, pMove, ai, true); }
  }

  if (!G.over) {
    await endOfTurn();
    G.turn++;
    if (G.turn>100) return endBattle('draw');
    G.waiting=false;
    renderBattle();
  }
}

async function playerSwitch(idx) {
  if (G.waiting||G.over) return;
  G.waiting=true;
  const prev = G.playerTeam[G.playerIdx];
  addLog(`${prev.name}은(는) 물러났다.`,'log-sys');
  // 교체 시 역린 초기화
  prev.outrageTurns=0; prev.outrageMove=null;
  G.playerIdx=idx;
  const next=G.playerTeam[idx];
  addLog(`💪 ${next.name} 등장!`,'log-new');
  renderBattle();
  await sleep(300);
  const aiMove=chooseAiMove(G.aiTeam[G.aiIdx], next);
  await execMove(G.aiTeam[G.aiIdx], aiMove, next, false);
  if (!G.over) {
    await endOfTurn();
    G.turn++;
    G.waiting=false;
    renderBattle();
  }
}

function calcEffSpe(p) {
  const base = p.speStat * rankMult(p.rankSpe);
  const itemBonus = p.item==='choice-scarf' ? 1.5 : 1;
  return base * itemBonus;
}

function chooseAiMove(me, foe) {
  // 역린 잠금
  if (me.outrageTurns>0) return me.moves.find(m=>m.special==='outrage') || me.moves[0];
  let best=me.moves[0], bestScore=-1;
  me.moves.forEach(m=>{
    if (m.pp<=0) return;
    let score;
    if (m.cat==='status') score=25;
    else score=m.power*typeMult(m.type,foe.types)*(me.types.includes(m.type)?1.5:1);
    if (score>bestScore){bestScore=score;best=m;}
  });
  return best;
}

async function execMove(attacker, move, defender, isPlayer) {
  if (!move) return;
  const label = isPlayer ? '플레이어' : 'AI';
  const cls = isPlayer ? 'log-new' : 'log-ai';

  // ── 수면 체크 ──
  if (attacker.status==='sleep') {
    attacker.statusTurns = (attacker.statusTurns||0)-1;
    if (attacker.statusTurns<=0) {
      attacker.status='none';
      addLog(`${attacker.name}이(가) 잠에서 깨어났다!`,'log-new');
    } else {
      addLog(`${attacker.name}은(는) 잠들어 있다...`,'log-sys');
      return;
    }
  }
  // ── 얼음 체크 ──
  if (attacker.status==='freeze') {
    if (Math.random()<.2) { attacker.status='none'; addLog(`${attacker.name}의 얼음이 녹았다!`,'log-new'); }
    else { addLog(`${attacker.name}은(는) 꽁꽁 얼어붙어 있다!`,'log-sys'); return; }
  }
  // ── 마비 체크 ──
  if (attacker.status==='paralysis' && Math.random()<.25) {
    addLog(`${attacker.name}은(는) 몸이 굳어 움직일 수 없다!`,'log-sys'); return;
  }
  // ── 혼란 체크 ──
  if (attacker.confused) {
    attacker.confusionTurns--;
    if (attacker.confusionTurns<=0) {
      attacker.confused=false;
      addLog(`${attacker.name}의 혼란이 풀렸다!`,'log-new');
    } else if (Math.random()<.33) {
      const selfDmg=Math.max(1,Math.floor(((2*attacker.level/5+2)*40*attacker.atkStat/attacker.defStat)/50+2));
      attacker.currentHp=Math.max(0,attacker.currentHp-selfDmg);
      addLog(`${attacker.name}은(는) 혼란 상태에서 자신을 공격했다! (-${selfDmg}HP)`,'log-dmg');
      renderBattle();
      if (attacker.currentHp<=0) { await handleFaint(attacker, isPlayer); return; }
      return;
    }
  }

  // ── 역린 로직 ──
  if (move.special==='outrage') {
    if (attacker.outrageTurns===0) {
      attacker.outrageTurns = 2 + Math.floor(Math.random()*2); // 2 or 3
      attacker.outrageMove = move;
    }
    attacker.outrageTurns--;
    addLog(`${label}의 ${attacker.name}이(가) ${move.name}을(를) 사용!`, cls);
    animSprite(isPlayer?'playerSprite':'oppSprite','atk');
    if (move.pp>0) move.pp--;
    // 역린 데미지
    const dmg = calcDamage(attacker, move, defender);
    defender.currentHp = Math.max(0, Math.floor(defender.currentHp - dmg));
    addLog(`  ${defender.name}에게 ${Math.floor(dmg)} 데미지! (HP: ${Math.max(0,Math.floor(defender.currentHp))}/${defender.maxHp})`,'log-dmg');
    animSprite(isPlayer?'oppSprite':'playerSprite','hit');
    renderBattle();
    if (attacker.outrageTurns===0) {
      // 역린 종료 → 혼란 확정
      attacker.confused=true;
      attacker.confusionTurns=2+Math.floor(Math.random()*3);
      attacker.outrageMove=null;
      addLog(`${attacker.name}은(는) 혼란에 빠졌다!`,'log-dmg');
    }
    await sleep(200);
    if (defender.currentHp<=0) await handleFaint(defender, !isPlayer);
    return;
  }

  // ── 하품 로직 ──
  if (move.special==='yawn') {
    if (defender.status!=='none'||defender.yawnCounter>0) {
      addLog(`${defender.name}에게는 효과가 없었다!`,'log-sys'); return;
    }
    defender.yawnCounter=2; // 2턴 후 잠듦 (이번 턴 포함)
    addLog(`${label}의 ${attacker.name}이(가) ${move.name}을(를) 사용!`, cls);
    addLog(`${defender.name}은(는) 졸려하고 있다...`,'log-sys');
    if (move.pp>0) move.pp--;
    renderBattle();
    return;
  }

  addLog(`${label}의 ${attacker.name}이(가) ${move.name}을(를) 사용!`, cls);
  animSprite(isPlayer?'playerSprite':'oppSprite','atk');
  if (move.pp>0) move.pp--;

  // 명중 체크
  if (move.acc>0 && Math.random()>move.acc/100) {
    addLog('공격이 빗나갔다!','log-sys'); return;
  }

  // 변화기술
  if (move.cat==='status') {
    await applyStatusEffect(attacker, defender, move, isPlayer);
    renderBattle();
    return;
  }

  // 타입 배수
  const mult=typeMult(move.type,defender.types);
  if (mult===0){addLog('효과가 없는 것 같다...','log-neff');return;}
  if (mult>=2) addLog('효과가 굉장한 것 같다!','log-eff');
  else if (mult<=0.5) addLog('효과가 별로인 것 같다...','log-neff');

  const crit=Math.random()<(1/24);
  if (crit) addLog('급소에 맞았다!','log-eff');

  let dmg=calcDamage(attacker,move,defender,crit);
  // 도구 보정
  if (attacker.item==='choice-band'&&move.cat==='physical') dmg=Math.floor(dmg*1.5);
  if (attacker.item==='choice-specs'&&move.cat==='special') dmg=Math.floor(dmg*1.5);
  if (attacker.item==='life-orb') { dmg=Math.floor(dmg*1.3); attacker.currentHp=Math.max(0,attacker.currentHp-Math.floor(attacker.maxHp/10)); }

  await sleep(150);
  animSprite(isPlayer?'oppSprite':'playerSprite','hit');
  defender.currentHp=Math.max(0,Math.floor(defender.currentHp-dmg));
  addLog(`  ${defender.name}에게 ${Math.floor(dmg)} 데미지! (HP: ${Math.max(0,Math.floor(defender.currentHp))}/${defender.maxHp})`,'log-dmg');

  // 기합의 띠
  if (defender.item==='focus-sash' && defender.currentHp===0 && !defender._sashUsed && defender.currentHp+dmg===defender.maxHp) {
    defender.currentHp=1; defender._sashUsed=true;
    addLog(`${defender.name}은(는) 기합의 띠로 버텼다!`,'log-eff');
  }

  renderBattle();

  // 접촉 기술 덮치기 헬멧 반동
  if (move.cat==='physical' && defender.item==='rocky-helmet') {
    const recoil=Math.floor(attacker.maxHp/6);
    attacker.currentHp=Math.max(0,attacker.currentHp-recoil);
    addLog(`${attacker.name}은(는) 덮치기헬멧의 반동 데미지를 받았다! (-${recoil}HP)`,'log-dmg');
  }

  // 부가효과
  if (move.effect && move.effectChance && Math.random()<move.effectChance/100) {
    applyMoveEffect(defender, move.effect);
  }

  await sleep(200);
  if (defender.currentHp<=0) await handleFaint(defender, !isPlayer);
  if (attacker.currentHp<=0 && !attacker.fainted) await handleFaint(attacker, isPlayer);
}

function calcDamage(atk, move, def, crit=false) {
  const atkStat = move.cat==='physical' ? atk.atkStat*rankMult(atk.rankAtk) : atk.spaStat*rankMult(atk.rankSpa);
  const defStat = move.cat==='physical' ? def.defStat*rankMult(crit?0:def.rankDef) : def.spdStat*rankMult(crit?0:def.rankSpd);
  const stab = atk.types.includes(move.type)?1.5:1;
  const typeM = typeMult(move.type, def.types);
  const burn = atk.status==='burn'&&move.cat==='physical'?.5:1;
  const rand = 0.85+Math.random()*0.15;
  const critM = crit?1.5:1;
  return Math.max(1, Math.floor(((2*atk.level/5+2)*move.power*atkStat/defStat)/50+2) * stab * typeM * burn * rand * critM | 0);
}

function rankMult(r){const t={'-6':2/8,'-5':2/7,'-4':2/6,'-3':2/5,'-2':.5,'-1':2/3,'0':1,'1':1.5,'2':2,'3':2.5,'4':3,'5':3.5,'6':4};return t[String(r)]||1;}

async function applyStatusEffect(attacker, defender, move, isPlayer) {
  switch(move.effect||'') {
    case 'burn': if(setStatus(defender,'burn')) addLog(`${defender.name}에게 화상!`,'log-dmg'); break;
    case 'sleep': if(setStatus(defender,'sleep')){defender.statusTurns=2+Math.floor(Math.random()*2);addLog(`${defender.name}이(가) 잠들었다!`,'log-dmg');} break;
    case 'poison': if(setStatus(defender,'poison')) addLog(`${defender.name}이(가) 독에 걸렸다!`,'log-dmg'); break;
    case 'paralyze': if(setStatus(defender,'paralysis')) addLog(`${defender.name}이(가) 마비됐다!`,'log-dmg'); break;
    case 'heal': { const h=Math.floor(attacker.maxHp/2); attacker.currentHp=Math.min(attacker.maxHp,attacker.currentHp+h); addLog(`${attacker.name}이(가) HP ${h} 회복!`,'log-eff'); break; }
    default: addLog(`${attacker.name}이(가) 변화기술을 사용했다.`,'log-sys');
  }
}

function applyMoveEffect(p, effect) {
  const m={burn:'burn',paralyze:'paralysis',freeze:'freeze',sleep:'sleep',poison:'poison'};
  if (m[effect]) setStatus(p, m[effect]);
}

function setStatus(p, s) {
  if (p.status!=='none') return false;
  p.status=s;
  return true;
}

async function handleFaint(p, isPlayer) {
  if (p.fainted) return;
  p.fainted=true;
  const side = isPlayer?'플레이어':'AI';
  addLog(`${p.name}은(는) 쓰러졌다!`, isPlayer?'log-lose':'log-win');
  await sleep(300);
  renderBattle();

  if (isPlayer) {
    const next = G.playerTeam.findIndex((x,i)=>i!==G.playerIdx&&!x.fainted);
    if (next===-1) { endBattle('lose'); return; }
    G.playerIdx=next;
    addLog(`💪 ${G.playerTeam[next].name} 등장!`,'log-new');
    // 역린 초기화
    G.playerTeam[next].outrageTurns=0;
    renderBattle();
  } else {
    const next = G.aiTeam.findIndex((x,i)=>i!==G.aiIdx&&!x.fainted);
    if (next===-1) { endBattle('win'); return; }
    G.aiIdx=next;
    G.aiTeam[next].revealed=true;
    addLog(`상대: ${G.aiTeam[next].name} 등장!`,'log-ai');
    renderBattle();
  }
}

async function endOfTurn() {
  for (const p of [G.playerTeam[G.playerIdx], G.aiTeam[G.aiIdx]]) {
    if (p.fainted) continue;

    // ── 하품 카운터 처리 ──
    if (p.yawnCounter>0) {
      p.yawnCounter--;
      if (p.yawnCounter===0 && p.status==='none') {
        p.status='sleep';
        p.statusTurns=2+Math.floor(Math.random()*2);
        addLog(`${p.name}은(는) 잠들어버렸다!`,'log-dmg');
      }
    }

    // 상태이상 지속피해
    if (p.status==='burn') {
      const d=Math.max(1,Math.floor(p.maxHp/16));
      p.currentHp=Math.max(0,p.currentHp-d);
      addLog(`${p.name}은(는) 화상으로 체력이 줄었다! (-${d}HP)`,'log-dmg');
    } else if (p.status==='poison') {
      const d=Math.max(1,Math.floor(p.maxHp/8));
      p.currentHp=Math.max(0,p.currentHp-d);
      addLog(`${p.name}은(는) 독으로 체력이 줄었다! (-${d}HP)`,'log-dmg');
    }

    // 먹다남은음식
    if (p.item==='leftovers') {
      const h=Math.max(1,Math.floor(p.maxHp/16));
      p.currentHp=Math.min(p.maxHp,p.currentHp+h);
      addLog(`${p.name}은(는) 먹다남은음식으로 체력을 회복했다! (+${h}HP)`,'log-eff');
    }

    renderBattle();
    if (p.currentHp<=0 && !p.fainted) {
      const isPlayer = G.playerTeam.includes(p);
      await handleFaint(p, isPlayer);
    }
  }
}

// ══════════════════════════════════════════
// 1번 수정: 승패 판정
// ══════════════════════════════════════════
function endBattle(result) {
  G.over=true; G.waiting=false;
  // 명확한 승패 재확인
  const playerAlive = G.playerTeam.filter(p=>!p.fainted).length;
  const aiAlive = G.aiTeam.filter(p=>!p.fainted).length;
  if (result!=='draw') {
    if (aiAlive===0 && playerAlive>0) result='win';
    else if (playerAlive===0 && aiAlive>0) result='lose';
    else if (playerAlive===0 && aiAlive===0) result='draw';
  }
  const msgs={
    win:{icon:'🏆',title:'VICTORY!',cls:'win',sub:'AI 트레이너를 물리쳤다!'},
    lose:{icon:'💀',title:'DEFEATED...',cls:'lose',sub:'AI 트레이너에게 졌다... 다시 도전!'},
    draw:{icon:'⏰',title:'TIME OVER',cls:'',sub:'턴 제한 초과! 무승부.'},
  };
  const m=msgs[result]||msgs.draw;
  document.getElementById('resultIcon').textContent=m.icon;
  document.getElementById('resultTitle').textContent=m.title;
  document.getElementById('resultTitle').className='result-title '+m.cls;
  document.getElementById('resultSub').textContent=m.sub;
  document.getElementById('resultStats').textContent=`${G.turn}턴 진행 | 내 포켓몬 생존: ${G.playerTeam.filter(p=>!p.fainted).length}마리`;
  addLog(result==='win'?'🏆 승리!':result==='lose'?'💀 패배...':'⏰ 시간 초과', result==='win'?'log-win':'log-lose');
  setTimeout(()=>document.getElementById('resultOverlay').classList.add('show'),800);
}

// ══════════════════════════════════════════
// 유틸
// ══════════════════════════════════════════
function spriteUrl(id,back=false){return`https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${back?'back/':''}${id}.png`;}
function setHp(barId,numId,cur,max){
  const ratio=Math.max(0,cur/max);
  const bar=document.getElementById(barId);
  bar.style.width=(ratio*100)+'%';
  bar.className='hp-bar-fill '+(ratio>.5?'hp-high':ratio>.25?'hp-mid':'hp-low');
  document.getElementById(numId).textContent=`${Math.max(0,Math.floor(cur))} / ${Math.floor(max)}`;
}
function setTypes(elId,types){document.getElementById(elId).innerHTML=types.map(t=>`<span class="type-badge type-${t}">${t.toUpperCase()}</span>`).join('');}
function setStatusBadge(elId,p){
  const el=document.getElementById(elId);
  const map={burn:'🔥화상',paralysis:'⚡마비',sleep:'💤잠듦',freeze:'❄️얼음',poison:'☠️독',confusion:'😵혼란'};
  const cls={burn:'s-burn',paralysis:'s-paralysis',sleep:'s-sleep',freeze:'s-freeze',poison:'s-poison',confusion:'s-confusion'};
  let statusList=[];
  if (p.status!=='none'&&map[p.status]) statusList.push({label:map[p.status],cls:cls[p.status]});
  if (p.confused) statusList.push({label:'😵혼란',cls:'s-confusion'});
  if (p.yawnCounter>0) statusList.push({label:`💤하품(${p.yawnCounter})`,cls:'s-yawn'});
  const badge=document.getElementById(elId);
  if (statusList.length>0){
    badge.style.display='inline-block';
    badge.textContent=statusList[0].label;
    badge.className='sbadge '+statusList[0].cls;
  } else {badge.style.display='none';}
}
function tc(t){const c={fire:'#ff6b35',water:'#38bdf8',grass:'#4ade80',electric:'#fbbf24',ice:'#a5f3fc',fighting:'#f97316',poison:'#c084fc',ground:'#ca8a04',flying:'#818cf8',psychic:'#ec4899',bug:'#84cc16',rock:'#a8a29e',ghost:'#a78bfa',dragon:'#60a5fa',dark:'#a8a29e',steel:'#94a3b8',fairy:'#f9a8d4',normal:'#d4d4d8'};return c[t]||'#e2e8f0';}
function itemName(i){const m={'choice-band':'구애띠','choice-specs':'구애안경','choice-scarf':'구애스카프',leftovers:'먹다남은음식','life-orb':'생명의구슬','assault-vest':'돌격조끼','focus-sash':'기합의띠','rocky-helmet':'덮치기헬멧'};return m[i]||i;}
function animSprite(id,cls){const el=document.getElementById(id);el.classList.remove('atk','hit');void el.offsetWidth;el.classList.add(cls);setTimeout(()=>el.classList.remove(cls),500);}
function sleep(ms){return new Promise(r=>setTimeout(r,ms));}
function clearLog(){document.getElementById('battleLog').innerHTML='';}
function addLog(text,cls=''){const log=document.getElementById('battleLog');const d=document.createElement('div');d.className='log-line '+cls;d.textContent=text;log.appendChild(d);log.scrollTop=log.scrollHeight;}
function setButtonsDisabled(v){document.querySelectorAll('.move-btn,.switch-btn').forEach(b=>b.disabled=v);}
function switchTab(tab){
  document.getElementById('fightPanel').style.display=tab==='fight'?'':'none';
  document.getElementById('pokePanel').style.display=tab==='poke'?'':'none';
  document.getElementById('tabFight').classList.toggle('active',tab==='fight');
  document.getElementById('tabPoke').classList.toggle('active',tab==='poke');
}

// ══════════════════════════════════════════
// 초기화
// ══════════════════════════════════════════
checkServer();
renderGrid();
</script>
</body>
</html>
